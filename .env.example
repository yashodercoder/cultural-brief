# Copy to .env and fill in values. Never commit .env.

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_...

# Where the daily email goes (must be your Resend signup email while using onboarding@resend.dev)
BRIEF_TO=you@youremail.com

# Optional — defaults to onboarding@resend.dev (Resend free sender, no domain needed)
# Switch to a verified domain sender when ready
# BRIEF_FROM=brief@yourdomain.com
